# Buena Context Engine — environment variables
# All settings use the APP_ prefix (see app/core/config.py).
# Copy to .env and fill in secrets. Defaults shown after `=`.

# Runtime environment: dev | staging | prod
APP_ENV=dev

# Log level: DEBUG | INFO | WARNING | ERROR
APP_LOG_LEVEL=INFO

# Filesystem layout (absolute or relative to repo root)
APP_WIKI_DIR=./wiki
APP_NORMALIZE_DIR=./normalize
APP_OUTPUT_DIR=./output

# Anthropic API key for LLM calls (required in non-test envs)
APP_ANTHROPIC_API_KEY=

# HMAC-SHA256 secret used to verify POST /webhook/ingest payloads
APP_WEBHOOK_HMAC_SECRET=

# Model identifiers — pin defaults; override per-env if needed
APP_HAIKU_MODEL=claude-haiku-4-5-20251001
APP_SONNET_MODEL=claude-sonnet-4-6
